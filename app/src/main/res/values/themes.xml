<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.ConnectApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary_social</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="colorSecondary">@color/accent_social</item>
        <item name="colorSecondaryVariant">@color/accent_social</item>
        <item name="colorOnSecondary">@color/white</item>

        <item name="android:windowBackground">@color/white</item>
        <item name="android:statusBarColor">@color/primary_social</item>

        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.ConnectApp.SmallComponent</item>
