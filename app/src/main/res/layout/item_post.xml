<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/txtPostAutor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="autor@email.com"
            android:textStyle="bold"
            android:textColor="@color/primary_social" />

        <TextView
            android:id="@+id/txtPostLocal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Localização"
            android:textSize="12sp" />

        <ImageView
            android:id="@+id/imgPostFeed"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="8dp"
            android:scaleType="centerCrop"
            android:background="#EEEEEE" />

        <TextView
            android:id="@+id/txtPostDescricao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Legenda da foto aqui..."
            android:textColor="#333333" />

    </LinearLayout>
</androidx.cardview.widget.CardView>